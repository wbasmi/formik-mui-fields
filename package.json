{
  "name": "formik-mui-fields",
  "version": "0.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Formik-connected MUI form field components with automatic value, validation, and error handling",
  "keywords": [
    "formik",
    "mui",
    "material-ui",
    "react",
    "form",
    "fields",
    "text-field",
    "select",
    "checkbox",
    "switch",
    "slider",
    "rating",
    "autocomplete",
    "radio-group",
    "toggle-button",
    "color-picker",
    "date-picker",
    "image-upload"
  ],
  "license": "MIT",
  "author": "Wadii Basmi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wadiibasmi/formik-mui-fields.git"
  },
  "homepage": "https://github.com/wadiibasmi/formik-mui-fields#readme",
  "bugs": {
    "url": "https://github.com/wadiibasmi/formik-mui-fields/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./date-picker": {
      "import": {
        "types": "./dist/date-picker.d.ts",
        "default": "./dist/date-picker.js"
      },
      "require": {
        "types": "./dist/date-picker.d.cts",
        "default": "./dist/date-picker.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "version": "changeset version"
  },
  "dependencies": {
    "react-color": "^2.19.3",
    "react-image-crop": "^11.0.10"
  },
  "peerDependencies": {
    "@mui/icons-material": ">=7",
    "@mui/material": ">=7",
    "@mui/x-date-pickers": ">=7",
    "dayjs": ">=1",
    "formik": ">=2",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@mui/icons-material": {
      "optional": true
    },
    "@mui/x-date-pickers": {
      "optional": true
    },
    "dayjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@chromatic-com/storybook": "^5.1.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^10.0.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/x-date-pickers": "^8.27.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-onboarding": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-color": "^3.0.13",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "dayjs": "^1.11.20",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "storybook": "^10.3.3",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
